# ── Discord ───────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications  (Bot → Reset Token)
DISCORD_TOKEN=your-bot-token-here

# The channel the bot posts new codes into. Right-click the channel in Discord
# (Developer Mode on) → Copy Channel ID.
CHANNEL_ID=000000000000000000

# Optional but recommended: your Discord server (guild) ID. If set, slash
# commands (/testpost, /codes, ...) register INSTANTLY in that server. Without
# it, Discord can take up to ~1 hour to show global commands. Right-click your
# server icon → Copy Server ID (Developer Mode on).
GUILD_ID=0

# Optional: a role to @mention when a new code is found (e.g. a "WuWa Codes" role).
# Leave blank or set to 0 to disable the ping.
PING_ROLE_ID=0

# ── Polling ─────────────────────────────────────────────────────────────────
# How often (minutes) to check the sources for new codes.
POLL_INTERVAL_MINUTES=30

# Where to keep the "already posted" database (inside the container this is a
# mounted volume so it survives restarts).
DB_PATH=/data/codes.db

# ── Behaviour ───────────────────────────────────────────────────────────────
# If true, on the very first run the bot records all currently-known codes as
# "already seen" WITHOUT posting them, so you don't get spammed with a backlog.
# After that first run it only posts genuinely new codes. Set to false if you
# WANT the current active codes posted on first launch.
SEED_SILENTLY=true

# Comma-separated list of sources to enable. Default: game8, pcgamesn (both
# cleanly separate active vs expired codes). "pockettactics" also exists but
# lists expired codes as active, so it's off by default.
ENABLED_SOURCES=game8,pcgamesn

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
