# Force LF on files that must run on Linux, regardless of the author's OS.
# Without this, Windows checkouts can introduce CRLF and break shell scripts
# ("bad interpreter") and the Docker build.
*.sh        text eol=lf
Dockerfile  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.py        text eol=lf
.env.example text eol=lf

# Keep release tarballs, build tooling, and local venvs out of the runtime
# tarball produced by `git archive`.
releases/        export-ignore
.venv/           export-ignore
build-release.sh export-ignore
VERSION          export-ignore
